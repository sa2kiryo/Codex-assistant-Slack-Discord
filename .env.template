# === Slack (Primary Platform) ===

# Slack Bot Token (xoxb-...)
# Get from: https://api.slack.com/apps > OAuth & Permissions
SLACK_BOT_TOKEN=

# Slack App-Level Token (xapp-...) for Socket Mode
# Get from: https://api.slack.com/apps > Basic Information > App-Level Tokens
SLACK_APP_TOKEN=

# Slack IDs
SLACK_USER_ID=
SLACK_BOT_ID=

# Enable Slack API tools
USE_SLACK_API=true

# Enable Slack mention responses
USE_SLACK_MENTION=true

# === Discord (Secondary Platform) ===

# Discord Bot Token
# Get from: https://discord.com/developers/applications
DISCORD_BOT_TOKEN=

# Discord IDs
# Enable Developer Mode in Discord settings to copy IDs
DISCORD_USER_ID=
DISCORD_BOT_ID=

# Enable Discord API tools
USE_DISCORD_API=true

# Enable mention responses
USE_DISCORD_MENTION=true

# === Other ===

# Notion API token (for Notion MCP)
# Get from: https://www.notion.so/my-integrations
NOTION_TOKEN=

# Codex model
CODEX_MODEL=gpt-5.4

# Emit startup event to trigger startup rules
EMIT_STARTUP_EVENT=true
